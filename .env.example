# ============================================================
# Prediction-market trading bot configuration
# Copy this file to .env and fill in values. NEVER commit .env.
# ============================================================

# =========================== KALSHI ==========================
# The bot trades on Kalshi (CFTC-regulated, legal for US users).
# Create API keys at: kalshi.com -> profile -> Settings -> API keys
# (use demo.kalshi.co for the fake-money demo environment first).

# The Key ID shown when you create the API key (a UUID).
KALSHI_API_KEY_ID=

# Path to the RSA private key file (.pem) Kalshi gives you exactly once
# when creating the key. Keep it next to .env, e.g. kalshi_demo.pem
# (*.pem is gitignored). Example: kalshi_demo.pem
KALSHI_PRIVATE_KEY_PATH=

# demo = fake-money sandbox (demo.kalshi.co account)  <- START HERE
# prod = real money (kalshi.com account)
KALSHI_ENV=demo

# The market to trade: its ticker, shown on every Kalshi market page,
# e.g. KXHIGHNY-26JUL03-B87.5
MARKET_TICKER=

# --- Safety rails (HARD RULES, enforced on every order path) ---
# true  = log what would happen, place ZERO real orders (default, keep it on)
# false = live trading enabled
DRY_RUN=true

# true = bot refuses to place ANY order, even in dry-run
KILL_SWITCH=false

# Max USD allowed in a single order. Orders above this are rejected.
MAX_ORDER_SIZE=5

# Max total USD across all open positions/orders. Orders that would push
# exposure past this are rejected.
MAX_TOTAL_EXPOSURE=20

# ==================== POLYMARKET (legacy) ====================
# Kept for the read-only Polymarket scripts (fetch_orderbook.py etc.).
# Polymarket's crypto CLOB geoblocks US trading, so the order scripts
# cannot be used from the US. Leave this section empty unless you use
# those read-only tools.

# --- Wallet / authentication ---
# Private key of your Polygon wallet (hex string, with or without 0x prefix).
# NEVER share this or commit it anywhere.
POLYGON_WALLET_PRIVATE_KEY=

# How your wallet holds funds on Polymarket:
#   0 = plain EOA wallet (you exported the key from MetaMask etc. and USDC
#       sits directly in that address)
#   1 = Polymarket account created via email/magic link
#   2 = Polymarket account created via browser wallet (MetaMask sign-in on
#       polymarket.com -> funds live in a proxy/safe address)
# If you deposited through the polymarket.com website, you almost certainly
# need 2 (or 1 for email accounts) plus POLY_FUNDER_ADDRESS below.
POLY_SIGNATURE_TYPE=0

# Only needed when POLY_SIGNATURE_TYPE is 1 or 2: the Polymarket proxy wallet
# address that actually holds your USDC (shown under your profile on
# polymarket.com). Leave empty for signature type 0.
POLY_FUNDER_ADDRESS=

# --- Polymarket CLOB endpoint ---
CLOB_API_URL=https://clob.polymarket.com
CHAIN_ID=137

# Polygon RPC node used for balance checks and one-time approvals.
# The default public node is fine; leave as is.
POLYGON_RPC_URL=https://polygon-rpc.com

# --- Market to read ---
# The CLOB token ID of ONE outcome (Yes or No) of one market: a long decimal
# number. Use find_market.py to look it up.
MARKET_TOKEN_ID=
